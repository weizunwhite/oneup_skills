{
  "$schema": "https://design-tokens.github.io/community-group/schemas/tokens.schema.json",
  "_meta": {
    "name": "OneUp Design System Tokens",
    "version": "1.0.0",
    "baseline": "暖色版 · 深咖 + 焦糖橙 + 米色",
    "lastUpdated": "2026-04-26",
    "owner": "Wei (One Up)",
    "notes": "Tailwind / Sanity / Next.js 项目可直接消费此 JSON。所有 CSS 变量在 tokens.css 中。"
  },

  "color": {
    "brown": {
      "darkest": { "value": "#2d1810", "description": "深咖 · 主深色" },
      "dark":    { "value": "#3d2817", "description": "深咖辅助" },
      "medium":  { "value": "#5c3a26", "description": "中棕（备用）" },
      "light":   { "value": "#7a6553", "description": "暖灰（次级文字）" }
    },
    "orange": {
      "deep":  { "value": "#a85d2c", "description": "深焦糖（hover）" },
      "base":  { "value": "#c97f4a", "description": "焦糖橙（主强调）" },
      "light": { "value": "#e0a070", "description": "浅焦糖" },
      "tint":  { "value": "rgba(201, 127, 74, 0.1)", "description": "10% 蒙版" },
      "line":  { "value": "rgba(201, 127, 74, 0.4)", "description": "细线" }
    },
    "background": {
      "primary":   { "value": "#fdfaf4", "description": "暖米白 · 主背景" },
      "secondary": { "value": "#f5efe4", "description": "米色 · section 间隔" },
      "card":      { "value": "#ffffff", "description": "卡片背景" }
    },
    "text": {
      "primary":   { "value": "#2d1810" },
      "secondary": { "value": "#7a6553" },
      "muted":     { "value": "rgba(45, 24, 16, 0.5)" }
    },
    "divider": { "value": "#e8dcc9" },
    "border":  { "value": "#eee6d8" },
    "status": {
      "success": { "value": "#5a8a4a", "description": "暖绿（不要用纯绿）" },
      "warning": { "value": "#d4925a" },
      "error":   { "value": "#b65a3e", "description": "暖砖红（不要用纯红）" }
    }
  },

  "typography": {
    "fontFamily": {
      "serifEn": { "value": "'Cormorant Garamond', 'EB Garamond', Georgia, serif" },
      "serifCn": { "value": "'Noto Serif SC', 'Source Han Serif SC', '思源宋体', serif" },
      "sans":    { "value": "'Noto Sans SC', 'Source Han Sans SC', -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif" },
      "mono":    { "value": "'JetBrains Mono', 'Fira Code', 'SF Mono', Menlo, monospace" }
    },
    "fontSize": {
      "xs":   { "value": "0.75rem",  "px": 12 },
      "sm":   { "value": "0.85rem",  "px": 13.6 },
      "base": { "value": "1rem",     "px": 16 },
      "md":   { "value": "1.05rem",  "px": 16.8 },
      "lg":   { "value": "1.2rem",   "px": 19.2 },
      "xl":   { "value": "1.4rem",   "px": 22.4 },
      "2xl":  { "value": "1.8rem",   "px": 28.8 },
      "3xl":  { "value": "2.2rem",   "px": 35.2 },
      "4xl":  { "value": "2.4rem",   "px": 38.4 },
      "hero": { "value": "clamp(2.4rem, 4.5vw, 3.8rem)" }
    },
    "fontWeight": {
      "light":  { "value": 300 },
      "normal": { "value": 400 },
      "medium": { "value": 500 },
      "bold":   { "value": 700 }
    },
    "letterSpacing": {
      "tight":   { "value": "-0.5px" },
      "normal":  { "value": "0" },
      "wide":    { "value": "1px" },
      "wider":   { "value": "2px" },
      "widest":  { "value": "4px" },
      "mega":    { "value": "5px" }
    },
    "lineHeight": {
      "tight":   { "value": 1.2 },
      "snug":    { "value": 1.4 },
      "normal":  { "value": 1.6 },
      "relaxed": { "value": 1.8 },
      "loose":   { "value": 2 }
    }
  },

  "spacing": {
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "8":  { "value": "32px" },
    "10": { "value": "40px" },
    "12": { "value": "48px" },
    "16": { "value": "64px" },
    "20": { "value": "80px" },
    "24": { "value": "96px" },
    "28": { "value": "112px", "description": "section vertical padding" }
  },

  "container": {
    "max":     { "value": "1200px" },
    "content": { "value": "720px",  "description": "长文阅读宽度" }
  },

  "borderRadius": {
    "none": { "value": "0",      "description": "默认 · 保持学院感" },
    "sm":   { "value": "2px" },
    "md":   { "value": "4px" },
    "lg":   { "value": "8px" },
    "full": { "value": "9999px" }
  },

  "shadow": {
    "sm": { "value": "0 4px 12px rgba(45, 24, 16, 0.04)" },
    "md": { "value": "0 10px 30px rgba(45, 24, 16, 0.06)" },
    "lg": { "value": "0 10px 40px rgba(45, 24, 16, 0.08)" }
  },

  "duration": {
    "fast":   { "value": "0.2s" },
    "normal": { "value": "0.3s" },
    "slow":   { "value": "1s",   "description": "fade-up 滚动渐入" }
  },

  "easing": {
    "default": { "value": "ease-out" },
    "snappy":  { "value": "cubic-bezier(0.16, 1, 0.3, 1)" }
  }
}
